/*
 * ATS-M7 app overlay
 * - Application-managed RS485 backend on USART2
 * - QSPI fixed partitions: first half reserved for FlashDB
 */

&usart2 {
	status = "okay";
};

/ {
	rs485_0: rs485_0 {
		compatible = "vendor,rs485";
		status = "okay";
		uart = <&usart2>;
		/* Adjust this pin to your actual RS485 DE wiring if different. */
		de-gpios = <&gpiod 3 GPIO_ACTIVE_HIGH>;
	};
};

&qspi_flash {
	/* Override SFDP QER value (7 unsupported by stm32-qspi driver path). */
	quad-enable-requirements = "S2B1v6";

	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		/* 64MiB external flash first half for FlashDB */
		flashdb_partition: partition@0 {
			label = "flashdb";
			reg = <0x00000000 0x02000000>;
		};

		/* Remaining second half for future data/filesystem */
		qspi_user_partition: partition@2000000 {
			label = "qspi_user";
			reg = <0x02000000 0x02000000>;
		};
	};
};
