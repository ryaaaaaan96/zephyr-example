/dts-v1/;
#include <mem.h>

/*
 * SoC include 文件选择说明：
 * - 当前使用 M7 核心，所以 include stm32h745Xi_m7.dtsi。
 * - Zephyr 不会为每个料号（如 STM32H745IIT6）单独提供 SoC dtsi，
 *   而是按系列/核提供通用描述，再由板级 DTS 覆盖。
 * - STM32H745IIT6 总 Flash 2MB，分为 flash0/flash1 两个 bank。
 */
#include <st/h7/stm32h745Xi_m7.dtsi>
#include "ats_stm32h745.dtsi"

/ {
	model = "ATS STM32H745IIT6 board (M7)";
	compatible = "ats,stm32h745";

	chosen {
		/*
		 * Console 输出配置：
		 * - UART4 用作 printk/shell console。
		 * - 注意 Zephyr 中 UART label 与设备树节点一致。
		 */
		zephyr,console = &usart6;
		zephyr,shell-uart = &usart6;

		/*
		 * M7 核心内存和 Flash 分配：
		 * - DTCM：内部高速 RAM，供 ISR/延迟敏感数据使用。
		 * - SRAM0：AXI SRAM，M7 主 RAM。
		 * - flash0：内部 Flash bank0，用于 M7 镜像。
		 */
		zephyr,dtcm = &dtcm;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};
};

/* 时钟配置 */
&clk_lsi { status = "okay"; };
&clk_hsi48 { status = "okay"; };
&clk_hsi {
	status = "okay"; /* 使用内部 HSI 64MHz 作为系统时钟源（调试阶段） */
};
&clk_hse {
	clock-frequency = <DT_FREQ_M(20)>;
	status = "okay"; /* 调试阶段未接外部晶振 */
};

/* PLL 配置参考 stm32h745i_disco */
&pll {
	div-m = <2>;
	mul-n = <80>;   /* 可根据目标 SYSCLK 调整 */
	div-p = <2>;
	div-q = <2>;
	div-r = <2>;
	clocks = <&clk_hse>;
	status = "okay";
};

/* RCC 主时钟配置 */
&rcc {
	clocks = <&pll>;
	clock-frequency = <DT_FREQ_M(400)>; /* SYSCLK = 400 MHz */
};


/* USART2 */
&usart2 {
	pinctrl-0 = <&usart2_tx_pd5 &usart2_rx_pd6>;
	pinctrl-names = "default";
	current-speed = <115200>;

	status = "okay";
    dmas = <&dma2 1 44 (STM32_DMA_PERIPH_TX | STM32_DMA_PRIORITY_HIGH) 0
            &dma2 2 43 (STM32_DMA_PERIPH_RX | STM32_DMA_PRIORITY_HIGH) 0>;
    dma-names = "tx", "rx";


};

/* USART3 */
&usart3 {
	pinctrl-0 = <&usart3_tx_pd8 &usart3_rx_pd9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* UART4 */
&uart4 {
	pinctrl-0 = <&uart4_tx_pb9 &uart4_rx_pb8>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

&gpiob {
    status = "okay";
};

/* USART6 用作 console */
&usart6 {
	pinctrl-0 = <&usart6_tx_pg14 &usart6_rx_pg9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* UART7 */
&uart7 {
	pinctrl-0 = <&uart7_tx_pe8 &uart7_rx_pe7>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* UART8 */
&uart8 {
	pinctrl-0 = <&uart8_tx_pj8 &uart8_rx_pj9>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};

/* 启用 DMA 控制器 */
&dma1 {
    status = "okay";
};

&dma2 {
    status = "okay";
};
&dmamux1 {
    status = "okay";   // ❌ 会导致 DMA 不工作
};

/*  PA11     ------> FDCAN1_RX
    PA12     ------> FDCAN1_TX  
*/



/* QSPI 外部 Flash 配置 */
&quadspi {
	pinctrl-0 = <&quadspi_bk1_io3_pf6
		     &quadspi_bk1_io2_pe2
		     &quadspi_bk1_io0_pf8
		     &quadspi_bk1_io1_pf9
		     &quadspi_clk_pf10
		     &quadspi_bk1_ncs_pg6>;
	pinctrl-names = "default";
	flash-id = <1>;
	ssht-enable;
	status = "okay";

	/* GD25B512MEYJG QSPI NOR Flash */
	qspi_flash: qspi-nor-flash@0 {
		compatible = "st,stm32-qspi-nor";
		reg = <0>;
		size = <DT_SIZE_M(512)>; /* 512 Mbits = 64 MiB */
		qspi-max-frequency = <40000000>;
		cs-high-time = <2>;
		spi-bus-width = <4>;
		writeoc = "PP_1_1_4";
		reset-cmd;
		status = "okay";
	};
};
